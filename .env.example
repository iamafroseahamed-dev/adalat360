# Supabase configuration (leave empty for demo mode with sample data)
# Fill these in when you have real Supabase credentials
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Without these variables the app runs in demo mode using mock services and sample data.
# With valid Supabase credentials the app will use Supabase Auth and the PostgreSQL database.
