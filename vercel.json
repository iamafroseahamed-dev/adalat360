{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/todays-cause-list.py": {
      "maxDuration": 60
    },
    "api/ecourts/case-details.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
